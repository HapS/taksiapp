{
    "file_types": {
        // "Tera" uzantıdaki dil adını birebir kullanın.
        "Tera (HTML)": ["html"],
    },

    "languages": {
        "Tera": {
            // İsteğe bağlı dil‑özel ayarlar
            "tab_size": 2,
            "format_on_save": "on",
            "formatter": {
                "external": {
                    "command": "prettier",
                    "arguments": [
                        "--stdin-filepath",
                        "{buffer_path}",
                        "--bracket-same-line",
                        "--html-whitespace-sensitivity",
                        "ignore",
                    ],
                },
            },
        },
        "HTML": {
            "formatter": {
                "external": {
                    "command": "prettier",
                    "arguments": [
                        "--stdin-filepath",
                        "{buffer_path}",
                        "--bracket-same-line",
                        "--html-whitespace-sensitivity",
                        "ignore",
                    ],
                },
            },
            "format_on_save": "on",
        },
    },
}
